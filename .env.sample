# Copy to .env and fill in.
# A long random string — the bot must send this same value. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
CHOPPER_API_SECRET=change-me-to-a-long-random-string

# Which Ollama model to run on CPU. llama3.2:3b is a good default.
# Alternatives: qwen2.5:3b, llama3.2:1b (faster/dumber), qwen3:8b (needs more RAM/time).
CHOPPER_MODEL=llama3.2:3b
